# ════════════════════════════════════════════════════════════════════════════
#  NIRBHAYA AI — Backend Environment Variables
#  HOW TO USE:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in YOUR values below (replace the placeholders)
#    3. Run backend:     node Backend/index.js
#
#  WITHOUT .env → App runs in DEMO mode (no real SMS, just console.log)
#  WITH .env    → App sends REAL SMS via AWS SNS to trusted contacts
# ════════════════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ── AWS Configuration ─────────────────────────────────────────────────────────
# WHERE TO GET THESE:
#   AWS Console → IAM → Users → Your User → Security Credentials → Create Access Key
#
# The IAM User MUST have these permissions attached:
#   • AmazonSNSFullAccess           (for sending SMS)
#   • AmazonDynamoDBFullAccess      (optional, for storing alerts)
#   • AmazonS3FullAccess            (optional, for evidence storage)

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── DynamoDB Tables ───────────────────────────────────────────────────────────
# WHERE TO CREATE:
#   AWS Console → DynamoDB → Create Table
#   Table 1: Name = nirbhaya-alerts,   Partition Key = id (String)
#   Table 2: Name = nirbhaya-contacts, Partition Key = userId (String)
#
# Leave blank to use in-memory storage (data lost on restart)
DYNAMODB_TABLE_ALERTS=nirbhaya-alerts
DYNAMODB_TABLE_CONTACTS=nirbhaya-contacts

# ── SNS Topic (optional — SMS works WITHOUT this) ─────────────────────────────
# Only needed if you want fan-out push notifications (multiple subscribers).
# Direct SMS to phone numbers works with just the credentials above.
# WHERE TO GET:
#   AWS Console → SNS → Topics → Create Topic → Copy the ARN
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:nirbhaya-alerts

# ── S3 Bucket for Evidence Storage ────────────────────────────────────────────
# WHERE TO CREATE:
#   AWS Console → S3 → Create Bucket → unique name → ap-south-1 → Block all public access ON
S3_EVIDENCE_BUCKET=nirbhaya-evidence-your-unique-suffix

# ════════════════════════════════════════════════════════════════════════════
# SMS CHECKLIST (Required before real SMS works):
#   ✅ 1. AWS_REGION set to ap-south-1  (Mumbai — best for India numbers)
#   ✅ 2. AWS_ACCESS_KEY_ID filled in
#   ✅ 3. AWS_SECRET_ACCESS_KEY filled in
#   ✅ 4. IAM user has sns:Publish permission
#   ✅ 5. SNS account moved out of Sandbox:
#          AWS Console → SNS → Text messaging (SMS) → Request spend limit increase
#   ✅ 6. Trusted contact numbers saved in app (Alert tab → Contacts)
#   ✅ 7. Phone numbers in +91XXXXXXXXXX format
# ════════════════════════════════════════════════════════════════════════════
